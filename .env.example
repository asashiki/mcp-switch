# ─────────────────────────────────────────────────────────────────────────────
# MCP Switch — environment
# Copy to `.env` and fill in. For Docker, the same file is read by compose.
# MCP Switch is a single service (the gateway); there is no separate backend.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
MCP_GATEWAY_HOST=127.0.0.1
MCP_GATEWAY_PORT=4577

# SQLite file holding agents/OAuth/audit/skills + the upstream-server registry.
MCP_AUTH_DB_PATH=./data/mcp-switch.sqlite

# ── OAuth + console ──────────────────────────────────────────────────────────
# Public base URL (e.g. https://mcp.example.com, no trailing slash). When SET,
# the gateway enables OAuth 2.1 + the management console at /console. Leave EMPTY
# for a local, anonymous /mcp endpoint (good for first-run / development).
MCP_PUBLIC_URL=
MCP_OAUTH_SCOPE=tools:read tools:write

# Console SPA CORS allowlist (comma-separated) — only needed if you serve the
# console from a different origin than the gateway.
MCP_CONSOLE_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Upstream MCP servers ─────────────────────────────────────────────────────
# Optional: pre-seed upstream servers as a JSON array. Usually left empty — add
# servers through the console instead.
#   [{"id":"context7","name":"Context7","description":"Up-to-date library docs",
#     "url":"https://mcp.context7.com/mcp","headers":{"CONTEXT7_API_KEY":"..."}}]
# `description` is optional (defaults to `name`); all other fields as shown.
REMOTE_MCP_SERVERS_JSON=

# ── Production (Docker) only ─────────────────────────────────────────────────
# Behind a reverse proxy, bind to all interfaces so the proxy can reach the
# container (otherwise compose defaults to 127.0.0.1 and external traffic times out).
# MCP_GATEWAY_BIND_HOST=0.0.0.0
#
# Publish on a different host port than the in-container port — handy when the
# default is already taken on the host, or when fronting several gateways.
# MCP_GATEWAY_HOST_PORT=4577

# ── Console dev server ───────────────────────────────────────────────────────
# Where `pnpm --filter @mcp-switch/console-web dev` proxies /api to.
VITE_DEV_PROXY=http://127.0.0.1:4577
