{
  "name": "@mcp-switch/mcp-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts src/cli/agents.ts src/cli/console-admin.ts --format esm && node scripts/fix-node-sqlite.mjs",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/mcp-gateway.test.ts src/auth/tokens.test.ts src/auth/store.test.ts",
    "smoke": "tsx src/cli/smoke-test.ts",
    "agents": "tsx src/cli/agents.ts"
  },
  "dependencies": {
    "@mcp-switch/config": "workspace:*",
    "@mcp-switch/schemas": "workspace:*",
    "@modelcontextprotocol/ext-apps": "^1.7.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastify": "^5.6.1",
    "zod": "^3.24.4"
  }
}
